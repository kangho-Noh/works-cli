# Copy this file to .env (which is git-ignored) or export these values in your shell.
# Never commit a populated .env file.

# NAVER WORKS Personal Access Token (Bearer token).
# Issue from your tenant's PAT issuance page. Required scopes depend on the
# commands you want to run — see README.md for the per-command scope table.
WORKS_PAT=your_personal_access_token_here

# Your NAVER WORKS user id (email format).
WORKS_USER_ID=user@yourdomain.com

# API base URL. The default is the internal-only endpoint. Do not change unless
# you know what you're doing.
WORKS_BASE_URL=https://corp.worksapis.com/v1.0
