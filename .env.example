# works-cli는 PAT를 환경변수에서만 로드합니다. 디스크 저장하지 않습니다.
# 이 파일은 사용 패턴 예시이며, 실제 .env 파일은 .gitignore로 차단됩니다.
# 가능하면 .env 파일 대신 셸에서 직접 export를 권장합니다.

# 필수
WORKS_PAT=your_personal_access_token_here

# 선택
# WORKS_BASE_URL=https://corp.worksapis.com/v1.0   # 사내 tenant (기본)
# WORKS_BASE_URL=https://www.worksapis.com/v1.0    # 공개 tenant
# WORKS_DEFAULT_TZ=Asia/Seoul
# WORKS_INTERNAL_DOMAINS=navercorp.com,worksmobile.com  # 다중 도메인 tenant용
